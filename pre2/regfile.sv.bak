module regfile(input  logic        clk, 
               input  logic        we3, 
               input  logic [4:0]  a1, a2, a3, 
               input  logic [31:0] wd3, 
               output logic [31:0] rd1, rd2);

    // 32 adet 32-bitlik yazmaç (register) tanımlıyoruz
    logic [31:0] rf[31:0];

    // Yazma işlemi (Write): Saat vuruşunun yükselen kenarında ve Write Enable (we3) 1 ise çalışır
    always_ff @(posedge clk) begin
        if (we3) rf[a3] <= wd3;
    end

    // Okuma işlemi (Read): Kombinasyoneldir, anında gerçekleşir.
    // RISC-V mimarisinde 0 numaralı yazmaç (x0) her zaman 0'a sabitlenmiştir (hardwired to 0).
    assign rd1 = (a1 != 0) ? rf[a1] : '0;
    assign rd2 = (a2 != 0) ? rf[a2] : '0;

endmodule